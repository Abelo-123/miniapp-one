<IfModule mod_headers.c>
    # Handle preflight OPTIONS at Apache level for speed and simplicity
    Header always set Access-Control-Allow-Origin "https://abelo-123.github.io"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

RewriteEngine On
# Avoid rewriting real files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Map route relative to api directory
RewriteRule ^(.*)$ index.php?route=/$1 [QSA,L]
