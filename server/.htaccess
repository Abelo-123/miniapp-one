<IfModule mod_headers.c>
    # Allow CORS from the frontend origin
    Header always set Access-Control-Allow-Origin "https://abelo-123.github.io"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

# Handle preflight OPTIONS requests at Apache level
# so they don't get swallowed before reaching Node.js
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>
# Limit Passenger to 1 process to avoid hitting cPanel resource limits
PassengerMaxPoolSize 1
PassengerMinInstances 1
